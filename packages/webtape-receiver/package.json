{
  "name": "webtape",
  "version": "1.7.0",
  "description": "CLI tool for WebTape: registers the Native Messaging host so the Chrome extension can record and analyze web sessions via AI without any manual server management.",
  "type": "module",
  "bin": {
    "webtape": "./dist/index.js",
    "webtape-receiver": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc && node scripts/pack-workspace.js",
    "dev": "tsx src/index.ts",
    "ws": "ln -snf ~/Desktop/WebTape WebTape && echo '✅ ~/Desktop/WebTape → WebTape'",
    "start": "npm run build && npm link && echo '\\n\\x1b[32m[Success]\\x1b[0m webtape 已完成编译并链接，现在你可以直接在终端输入 \\x1b[36mwebtape\\x1b[0m 进行本地测试。'",
    "prepublishOnly": "npm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/FurtherBank/WebTape.git",
    "directory": "packages/webtape-receiver"
  },
  "homepage": "https://github.com/FurtherBank/WebTape/tree/main/packages/webtape-receiver",
  "bugs": {
    "url": "https://github.com/FurtherBank/WebTape/issues"
  },
  "keywords": [
    "webtape",
    "native-messaging",
    "api-analysis",
    "chrome-extension",
    "llm"
  ],
  "license": "MIT",
  "dependencies": {
    "adm-zip": "^0.5.16",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "ejs": "^5.0.1",
    "minimatch": "^10.2.4",
    "ora": "^8.1.0"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.7",
    "@types/ejs": "^3.1.5",
    "@types/node": "^22.10.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
